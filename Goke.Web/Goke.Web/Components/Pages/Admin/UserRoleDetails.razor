@page "/user-roles/users/{UserId}"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Goke.Web.Data
@using Goke.Web.Services

@rendermode InteractiveServer
@attribute [Authorize(Roles = "Administrators")]

@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject NavigationManager NavigationManager
@inject AdminActivityLog ActivityLog
@inject AdminStatusMessageStore StatusMessageStore

<PageTitle>User Role Details</PageTitle>

<h1>User Role Details</h1>

<div class="mb-4 d-flex flex-wrap gap-2">
    <a class="btn btn-outline-secondary" href="/user-roles/users">Back to users</a>
    <a class="btn btn-outline-secondary" href="/user-roles">Back to overview</a>
</div>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert alert-success" role="alert">@statusMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (userEntry is null)
{
    <div class="alert alert-warning" role="alert">User not found.</div>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <h2 class="h5">User</h2>
            <dl class="row mb-0">
                <dt class="col-sm-3">User name</dt>
                <dd class="col-sm-9">@userEntry.UserName</dd>
                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@userEntry.Email</dd>
                <dt class="col-sm-3">Email confirmed</dt>
                <dd class="col-sm-9">@(userEntry.EmailConfirmed ? "Yes" : "No")</dd>
                <dt class="col-sm-3">Lockout enabled</dt>
                <dd class="col-sm-9">@(userEntry.LockoutEnabled ? "Yes" : "No")</dd>
                <dt class="col-sm-3">Locked out</dt>
                <dd class="col-sm-9">@(userEntry.IsLockedOut ? "Yes" : "No")</dd>
            </dl>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h2 class="h5">Account actions</h2>
            <div class="d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-outline-warning" @onclick="ToggleLockoutAsync" disabled="@isBusy">@(userEntry.IsLockedOut ? "Unlock user" : "Lock user")</button>
                <button type="button" class="btn btn-outline-secondary" @onclick="ResetAccessFailedCountAsync" disabled="@isBusy">Reset access failed count</button>
                @if (pendingDeleteConfirmation)
                {
                    <button type="button" class="btn btn-danger" @onclick="ConfirmDeleteUserAsync" disabled="@isBusy">Confirm delete</button>
                    <button type="button" class="btn btn-outline-secondary" @onclick="CancelDeleteUser" disabled="@isBusy">Cancel</button>
                }
                else
                {
                    <button type="button" class="btn btn-outline-danger" @onclick="RequestDeleteUser" disabled="@isBusy">Delete user</button>
                }
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h2 class="h5">Reset password</h2>
            <EditForm Model="resetPasswordInput" OnValidSubmit="ResetPasswordAsync">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger" role="alert" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label" for="new-password">New password</label>
                        <InputText id="new-password" type="password" @bind-Value="resetPasswordInput.Password" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label" for="confirm-new-password">Confirm password</label>
                        <InputText id="confirm-new-password" type="password" @bind-Value="resetPasswordInput.ConfirmPassword" class="form-control" />
                    </div>
                </div>
                <button type="submit" class="btn btn-primary mt-3" disabled="@isBusy">Reset password</button>
            </EditForm>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h2 class="h5">Add to role</h2>
            @if (availableRoles.Count == 0)
            {
                <p class="mb-0 text-secondary">No additional roles available.</p>
            }
            else
            {
                <div class="input-group">
                    <InputSelect @bind-Value="selectedRole" class="form-select" disabled="@isBusy">
                        <option value="">Select role</option>
                        @foreach (var role in availableRoles)
                        {
                            <option value="@role">@role</option>
                        }
                    </InputSelect>
                    <button type="button" class="btn btn-primary" @onclick="AddToRoleAsync" disabled="@isBusy">Add</button>
                </div>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h2 class="h5">Current roles</h2>
            @if (assignedRoles.Count == 0)
            {
                <p class="mb-0 text-secondary">This user is not assigned to any roles.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th scope="col">Role</th>
                                <th scope="col">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var role in assignedRoles)
                            {
                                <tr>
                                    <td>@role</td>
                                    <td>
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoveFromRoleAsync(role)" disabled="@isBusy">Remove</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter]
    public string UserId { get; set; } = string.Empty;

    private ApplicationUser? user;
    private UserEntry? userEntry;
    private readonly ResetPasswordInputModel resetPasswordInput = new();
    private readonly List<string> assignedRoles = [];
    private readonly List<string> availableRoles = [];
    private bool isBusy;
    private bool pendingDeleteConfirmation;
    private string? selectedRole;
    private string? statusMessage;
    private string? errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        statusMessage = null;
        errorMessage = null;
        pendingDeleteConfirmation = false;
        userEntry = null;
        user = await UserManager.FindByIdAsync(UserId);
        assignedRoles.Clear();
        availableRoles.Clear();
        selectedRole = null;

        if (user is null)
        {
            return;
        }

        userEntry = new UserEntry
        {
            UserId = user.Id,
            UserName = user.UserName ?? "(no username)",
            Email = user.Email ?? "(no email)",
            EmailConfirmed = user.EmailConfirmed,
            LockoutEnabled = user.LockoutEnabled,
            IsLockedOut = await UserManager.IsLockedOutAsync(user)
        };

        assignedRoles.AddRange((await UserManager.GetRolesAsync(user)).OrderBy(role => role));

        availableRoles.AddRange(await RoleManager.Roles
            .Where(role => role.Name != null && !assignedRoles.Contains(role.Name))
            .OrderBy(role => role.Name)
            .Select(role => role.Name!)
            .ToListAsync());
    }

    private async Task AddToRoleAsync()
    {
        statusMessage = null;
        errorMessage = null;

        if (user is null)
        {
            errorMessage = "User not found.";
            return;
        }

        var roleName = selectedRole?.Trim();
        if (string.IsNullOrWhiteSpace(roleName))
        {
            errorMessage = "Select a role to add.";
            return;
        }

        isBusy = true;

        try
        {
            var result = await UserManager.AddToRoleAsync(user, roleName);
            if (!result.Succeeded)
            {
                errorMessage = IdentityErrorFormatter.Format(result);
                return;
            }

            await LoadAsync();
            statusMessage = $"Added {userEntry?.UserName} to role '{roleName}'.";
            ActivityLog.Add("User added to role", statusMessage);
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task ToggleLockoutAsync()
    {
        statusMessage = null;
        errorMessage = null;

        if (user is null || userEntry is null)
        {
            errorMessage = "User not found.";
            return;
        }

        isBusy = true;

        try
        {
            var wasLockedOut = userEntry.IsLockedOut;
            IdentityResult result;
            if (wasLockedOut)
            {
                result = await UserManager.SetLockoutEndDateAsync(user, null);
            }
            else
            {
                if (!user.LockoutEnabled)
                {
                    var enableResult = await UserManager.SetLockoutEnabledAsync(user, true);
                    if (!enableResult.Succeeded)
                    {
                        errorMessage = IdentityErrorFormatter.Format(enableResult);
                        return;
                    }
                }

                result = await UserManager.SetLockoutEndDateAsync(user, DateTimeOffset.UtcNow.AddYears(100));
            }

            if (!result.Succeeded)
            {
                errorMessage = IdentityErrorFormatter.Format(result);
                return;
            }

            await LoadAsync();
            statusMessage = wasLockedOut ? $"Unlocked {userEntry?.UserName}." : $"Locked {userEntry?.UserName}.";
            ActivityLog.Add(wasLockedOut ? "User unlocked" : "User locked", statusMessage);
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task ResetAccessFailedCountAsync()
    {
        statusMessage = null;
        errorMessage = null;

        if (user is null || userEntry is null)
        {
            errorMessage = "User not found.";
            return;
        }

        isBusy = true;

        try
        {
            var result = await UserManager.ResetAccessFailedCountAsync(user);
            if (!result.Succeeded)
            {
                errorMessage = IdentityErrorFormatter.Format(result);
                return;
            }

            await LoadAsync();
            statusMessage = $"Reset access failed count for {userEntry.UserName}.";
            ActivityLog.Add("Access failed count reset", statusMessage);
        }
        finally
        {
            isBusy = false;
        }
    }

    private void RequestDeleteUser()
    {
        statusMessage = null;
        errorMessage = null;
        pendingDeleteConfirmation = true;
    }

    private void CancelDeleteUser()
    {
        pendingDeleteConfirmation = false;
    }

    private async Task ConfirmDeleteUserAsync()
    {
        statusMessage = null;
        errorMessage = null;

        if (user is null || userEntry is null)
        {
            errorMessage = "User not found.";
            return;
        }

        if (await UserManager.IsInRoleAsync(user, "Admin"))
        {
            errorMessage = "Admin users cannot be deleted here.";
            return;
        }

        isBusy = true;

        try
        {
            var deletedUserName = userEntry.UserName;
            var result = await UserManager.DeleteAsync(user);
            if (!result.Succeeded)
            {
                errorMessage = IdentityErrorFormatter.Format(result);
                return;
            }

            var message = $"Deleted {deletedUserName}.";
            ActivityLog.Add("User deleted", message);
            StatusMessageStore.Set(message);
            NavigationManager.NavigateTo("/user-roles/users");
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task ResetPasswordAsync()
    {
        statusMessage = null;
        errorMessage = null;

        if (user is null || userEntry is null)
        {
            errorMessage = "User not found.";
            return;
        }

        if (!string.Equals(resetPasswordInput.Password, resetPasswordInput.ConfirmPassword, StringComparison.Ordinal))
        {
            errorMessage = "The password and confirmation password do not match.";
            return;
        }

        isBusy = true;

        try
        {
            var resetToken = await UserManager.GeneratePasswordResetTokenAsync(user);
            var result = await UserManager.ResetPasswordAsync(user, resetToken, resetPasswordInput.Password);
            if (!result.Succeeded)
            {
                errorMessage = IdentityErrorFormatter.Format(result);
                return;
            }

            resetPasswordInput.Password = string.Empty;
            resetPasswordInput.ConfirmPassword = string.Empty;
            statusMessage = $"Reset password for {userEntry.UserName}.";
            ActivityLog.Add("Password reset", statusMessage);
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task RemoveFromRoleAsync(string roleName)
    {
        statusMessage = null;
        errorMessage = null;

        if (user is null)
        {
            errorMessage = "User not found.";
            return;
        }

        isBusy = true;

        try
        {
            var result = await UserManager.RemoveFromRoleAsync(user, roleName);
            if (!result.Succeeded)
            {
                errorMessage = IdentityErrorFormatter.Format(result);
                return;
            }

            await LoadAsync();
            statusMessage = $"Removed {userEntry?.UserName} from role '{roleName}'.";
            ActivityLog.Add("User removed from role", statusMessage);
        }
        finally
        {
            isBusy = false;
        }
    }

    private sealed class UserEntry
    {
        public required string UserId { get; init; }

        public required string UserName { get; init; }

        public required string Email { get; init; }

        public bool EmailConfirmed { get; init; }

        public bool LockoutEnabled { get; init; }

        public bool IsLockedOut { get; init; }
    }

    private sealed class ResetPasswordInputModel
    {
        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = string.Empty;

        [Required]
        [DataType(DataType.Password)]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
