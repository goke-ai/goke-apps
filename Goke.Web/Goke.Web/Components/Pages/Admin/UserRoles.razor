@page "/user-roles"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using Goke.Web.Data
@using Goke.Web.Services
@attribute [Authorize(Roles = "Administrators")]
@inject UserManager<ApplicationUser> UserManager
@inject RoleManager<IdentityRole> RoleManager
@inject AdminActivityLog ActivityLog
@inject AdminStatusMessageStore StatusMessageStore
@inject RoleAdministrationService RoleAdministrationService

<PageTitle>User Roles</PageTitle>

<h1>User Roles</h1>

<p>Manage application roles and assign roles to existing users.</p>

<div class="d-flex flex-wrap gap-2 mb-4">
    <a class="btn btn-outline-primary" href="/user-roles/users">Manage users</a>
    <a class="btn btn-outline-primary" href="/user-roles/users/create">Create user</a>
    <a class="btn btn-outline-primary" href="/user-roles/roles">Manage roles</a>
    <a class="btn btn-outline-primary" href="/user-roles/activity">View admin activity</a>
</div>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert alert-success" role="alert">@statusMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

<div class="row g-4">
    <div class="col-xl-4">
        <div class="card">
            <div class="card-body">
                <h2 class="h5">Create role</h2>
                <div class="input-group">
                    <InputText @bind-Value="newRoleName" class="form-control" placeholder="Role name" />
                    <button type="button" class="btn btn-primary" @onclick="CreateRoleAsync" disabled="@isBusy">Create</button>
                </div>
            </div>
        </div>

        <div class="card mt-4">
            <div class="card-body">
                <h2 class="h5">Existing roles</h2>
                @if (roles.Count == 0)
                {
                    <p class="mb-0 text-secondary">No roles created yet.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var role in roles)
                        {
                            <li class="list-group-item px-0 d-flex justify-content-between align-items-center gap-3">
                                <span>@role.Name</span>
                                <a class="btn btn-sm btn-outline-secondary" href="/user-roles/roles/@role.Id">Open</a>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-8">
        <div class="card">
            <div class="card-body">
                <h2 class="h5">Users</h2>

                @if (userEntries.Count == 0)
                {
                    <p class="mb-0 text-secondary">No users found.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th scope="col">User</th>
                                    <th scope="col">Email</th>
                                    <th scope="col">Current roles</th>
                                    <th scope="col">Add to role</th>
                                    <th scope="col"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var userEntry in userEntries)
                                {
                                    <tr>
                                        <td>@userEntry.UserName</td>
                                        <td>@userEntry.Email</td>
                                        <td>
                                            @if (userEntry.Roles.Count == 0)
                                            {
                                                <span class="text-secondary">None</span>
                                            }
                                            else
                                            {
                                                <div class="d-flex flex-wrap gap-2">
                                                    @foreach (var role in userEntry.Roles)
                                                    {
                                                        <span class="badge text-bg-secondary">@role</span>
                                                    }
                                                </div>
                                            }
                                        </td>
                                        <td>
                                            <div class="input-group">
                                                <InputSelect @bind-Value="userEntry.SelectedRole" class="form-select" disabled="@(roles.Count == 0 || isBusy)">
                                                    <option value="">Select role</option>
                                                    @foreach (var role in roles)
                                                    {
                                                        <option value="@role.Name">@role.Name</option>
                                                    }
                                                </InputSelect>
                                                <button type="button" class="btn btn-outline-primary" @onclick="() => AddUserToRoleAsync(userEntry)" disabled="@isBusy">Add</button>
                                            </div>
                                        </td>
                                        <td>
                                            <a class="btn btn-sm btn-outline-secondary" href="/user-roles/users/@userEntry.UserId">Open</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private readonly List<UserRoleEntry> userEntries = [];
    private readonly List<RoleEntry> roles = [];
    private bool isBusy;
    private string? newRoleName;
    private string? statusMessage;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        statusMessage = StatusMessageStore.Consume();
    }

    private async Task LoadAsync()
    {
        ClearMessages();

        roles.Clear();
        roles.AddRange(await RoleManager.Roles
            .OrderBy(role => role.Name)
            .Select(role => new RoleEntry
            {
                Id = role.Id,
                Name = role.Name!
            })
            .ToListAsync());

        userEntries.Clear();

        var users = await UserManager.Users
            .OrderBy(user => user.Email)
            .ThenBy(user => user.UserName)
            .ToListAsync();

        foreach (var user in users)
        {
            var userRoles = await UserManager.GetRolesAsync(user);

            userEntries.Add(new UserRoleEntry
            {
                UserId = user.Id,
                UserName = user.UserName ?? "(no username)",
                Email = user.Email ?? "(no email)",
                Roles = userRoles.OrderBy(role => role).ToList()
            });
        }
    }

    private async Task CreateRoleAsync()
    {
        ClearMessages();

        isBusy = true;

        try
        {
            var result = await RoleAdministrationService.CreateRoleAsync(newRoleName);
            if (!result.Succeeded)
            {
                errorMessage = result.ErrorMessage;
                return;
            }

            newRoleName = string.Empty;
            await LoadAsync();
            statusMessage = $"Created role '{result.RoleName}'.";
            ActivityLog.Add("Role created", statusMessage);
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task AddUserToRoleAsync(UserRoleEntry userEntry)
    {
        ClearMessages();

        var roleName = userEntry.SelectedRole?.Trim();
        if (string.IsNullOrWhiteSpace(roleName))
        {
            errorMessage = "Select a role to assign.";
            return;
        }

        var user = await UserManager.FindByIdAsync(userEntry.UserId);
        if (user is null)
        {
            errorMessage = "User could not be found.";
            return;
        }

        if (await UserManager.IsInRoleAsync(user, roleName))
        {
            errorMessage = $"{userEntry.UserName} is already in role '{roleName}'.";
            return;
        }

        isBusy = true;

        try
        {
            var result = await UserManager.AddToRoleAsync(user, roleName);
            if (!result.Succeeded)
            {
                errorMessage = IdentityErrorFormatter.Format(result);
                return;
            }

            await LoadAsync();
            statusMessage = $"Added {userEntry.UserName} to role '{roleName}'.";
            ActivityLog.Add("User added to role", statusMessage);
        }
        finally
        {
            isBusy = false;
        }
    }

    private void ClearMessages()
    {
        statusMessage = null;
        errorMessage = null;
    }

    private sealed class UserRoleEntry
    {
        public required string UserId { get; init; }

        public required string UserName { get; init; }

        public required string Email { get; init; }

        public List<string> Roles { get; init; } = [];

        public string? SelectedRole { get; set; }
    }

    private sealed class RoleEntry
    {
        public required string Id { get; init; }

        public required string Name { get; init; }
    }
}
