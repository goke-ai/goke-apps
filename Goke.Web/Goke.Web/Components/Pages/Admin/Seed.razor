@page "/admin/seed"
@using Microsoft.AspNetCore.Authorization
@using Goke.Web.Services
@using Goke.Web.Data
@using Microsoft.AspNetCore.Identity

@rendermode InteractiveServer
@attribute [AllowAnonymous]

@inject RoleManager<IdentityRole> RoleManager
@inject UserManager<ApplicationUser> UserManager
@inject IConfiguration Configuration
@inject ApplicationEmailSender ApplicationEmailSender
@inject SeedConfirmationService SeedConfirmationService

<PageTitle>Seed</PageTitle>

<h1>Seed</h1>

<p>Request a one-time confirmation code by email before running the seeding process.</p>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert alert-success" role="alert">@statusMessage</div>
}

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger" role="alert">@errorMessage</div>
}

@if (!string.IsNullOrWhiteSpace(seederEmail))
{
    <p class="text-secondary mb-2">Confirmation code destination: @seederEmail</p>
}

<div class="d-flex flex-wrap gap-2 align-items-end">
    <button type="button" class="btn btn-outline-primary" @onclick="SendConfirmationCodeAsync" disabled="@isBusy">Send confirmation code</button>
    <div>
        <label class="form-label" for="seed-confirmation-code">Confirmation code</label>
        <InputText id="seed-confirmation-code" @bind-Value="confirmationCode" class="form-control" placeholder="Enter the code from your email" />
    </div>
    <button type="button" class="btn btn-primary" @onclick="ConfirmAndSeedAsync" disabled="@(isBusy || !codeRequested)">Confirm and seed database</button>
</div>

@code {
    private string? seederEmail;
    private string? confirmationCode;
    private string? statusMessage;
    private string? errorMessage;
    private bool codeRequested;
    private bool isBusy;

    protected override Task OnInitializedAsync()
    {
        seederEmail = Configuration["SeederEmail"];

        if (string.IsNullOrWhiteSpace(seederEmail))
        {
            errorMessage = "Set SeederEmail in appsettings.json before requesting a seeding confirmation code.";
        }

        return Task.CompletedTask;
    }

    private async Task SendConfirmationCodeAsync()
    {
        statusMessage = null;
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(seederEmail))
        {
            errorMessage = "Set SeederEmail in appsettings.json before requesting a seeding confirmation code.";
            return;
        }

        isBusy = true;

        try
        {
            var result = SeedConfirmationService.IssueCode(seederEmail);
            var htmlMessage = $"Hello,<br><br>Your database seeding confirmation code is <strong>{result.Code}</strong>.<br><br>This code expires at {result.ExpiresAtUtc:yyyy-MM-dd HH:mm:ss} UTC.";

            await ApplicationEmailSender.SendEmailAsync(seederEmail, "Database seeding confirmation code", htmlMessage);

            codeRequested = true;
            confirmationCode = string.Empty;
            statusMessage = $"A confirmation code was sent to {seederEmail}.";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task ConfirmAndSeedAsync()
    {
        statusMessage = null;
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(seederEmail))
        {
            errorMessage = "Set SeederEmail in appsettings.json before confirming database seeding.";
            return;
        }

        var validationResult = SeedConfirmationService.ValidateCode(seederEmail, confirmationCode);
        if (!validationResult.Succeeded)
        {
            errorMessage = validationResult.ErrorMessage;
            return;
        }

        isBusy = true;

        try
        {
        await ApplicationSeeder.AddRoleAsync(RoleManager, Configuration);
        await ApplicationSeeder.AddUsersAsync(UserManager, ApplicationEmailSender, Configuration);
            confirmationCode = string.Empty;
            codeRequested = false;
            statusMessage = "Database seeding completed successfully.";
        }
        finally
        {
            isBusy = false;
        }
    }

}
